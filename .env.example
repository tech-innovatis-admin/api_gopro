# --------------------------------------------
# API GoPro - Environment Example
# Copie para .env e ajuste os valores
# --------------------------------------------

# Profile
# Em producao use "prod". Para desenvolvimento local, altere para "dev".
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://SEU_HOST:5432/SEU_BANCO?sslmode=require
SPRING_DATASOURCE_USERNAME=SEU_USUARIO
SPRING_DATASOURCE_PASSWORD=SUA_SENHA_FORTE

# Logs SQL (opcional)
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_FORMAT_SQL=false

# CORS (principalmente em producao)
APP_CORS_ALLOWED_ORIGINS=https://gopro.innovatismc.com

# Documents / Storage
APP_DOCUMENTS_S3_BUCKET=gopro-documents-prod
APP_DOCUMENTS_LOCAL_BASE_PATH=./storage/documents

# Business rules
APP_PROJECT_MAX_CONTRACT_VALUE=9999999999999.99

# AWS SDK (use IAM Role em producao; nao preencher chaves estaticas)
AWS_REGION=us-east-1
