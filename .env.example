# --------------------------------------------
# API GoPro - Environment Example
# Copie para .env e ajuste os valores
# --------------------------------------------

# Profile
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://nexus-db-prod.cmjoumo2iiux.us-east-1.rds.amazonaws.com:5432/gopro_v2?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=InnovaLabs86

# Logs SQL (opcional)
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_FORMAT_SQL=true

# CORS (principalmente em producao)
APP_CORS_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Documents / Storage
APP_DOCUMENTS_S3_BUCKET=gopro-documents-dev
APP_DOCUMENTS_LOCAL_BASE_PATH=./storage/documents

# Business rules
APP_PROJECT_MAX_CONTRACT_VALUE=9999999999999.99

# AWS SDK (use IAM Role em producao; nao preencher chaves estaticas)
AWS_REGION=us-east-1
