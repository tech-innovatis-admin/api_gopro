# --------------------------------------------
# API GoPro - Environment Example
# Copie para .env e ajuste os valores
# --------------------------------------------

# Profile
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://nexus-db-prod.cmjoumo2iiux.us-east-1.rds.amazonaws.com:5432/gopro_v2?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=InnovaLabs86

# Logs SQL (opcional)
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_FORMAT_SQL=true

# CORS (principalmente em producao)
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Documents / Storage
APP_DOCUMENTS_S3_BUCKET=gopro-documents-dev
APP_DOCUMENTS_LOCAL_BASE_PATH=./storage/documents

# Business rules
APP_PROJECT_MAX_CONTRACT_VALUE=9999999999999.99

# AWS SDK (use IAM Role em producao; nao preencher chaves estaticas)
AWS_REGION=us-east-1

# Auth / JWT
APP_AUTH_JWT_SECRET=troque-por-um-segredo-forte-com-no-minimo-32-bytes
APP_AUTH_JWT_EXPIRATION_SECONDS=43200
APP_AUTH_JWT_ISSUER=api-da-gopro
APP_URL=http://localhost:3000

# Link de convite para cadastro
APP_AUTH_INVITE_BASE_URL=http://localhost:3000/register
APP_AUTH_INVITE_DEFAULT_EXPIRATION_HOURS=72
APP_AUTH_PASSWORD_RESET_EXPIRATION_MINUTES=30

# Rate limit basico (login/cadastro por convite)
APP_AUTH_RATE_LIMIT_LOGIN_MAX_ATTEMPTS=8
APP_AUTH_RATE_LIMIT_FORGOT_PASSWORD_MAX_ATTEMPTS=5
APP_AUTH_RATE_LIMIT_RESET_PASSWORD_MAX_ATTEMPTS=10
APP_AUTH_RATE_LIMIT_REGISTER_MAX_ATTEMPTS=12
APP_AUTH_RATE_LIMIT_WINDOW_SECONDS=900

# Bootstrap de SUPERADMIN (habilite apenas na primeira inicializacao controlada)
APP_AUTH_BOOTSTRAP_SUPERADMIN_ENABLED=false
APP_AUTH_BOOTSTRAP_SUPERADMIN_EMAIL=tech@innovatismc.com
APP_AUTH_BOOTSTRAP_SUPERADMIN_USERNAME=tech
APP_AUTH_BOOTSTRAP_SUPERADMIN_PASSWORD=InnovaLabs86@
APP_AUTH_BOOTSTRAP_SUPERADMIN_FULL_NAME=Tech Innovatis

# SendGrid
SENDGRID_ENABLED=true
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=tech@innovatismc.com
SENDGRID_FROM_NAME=GoPro
SENDGRID_TEMPLATE_PROJECT_DEADLINE_ID=
SENDGRID_TEMPLATE_INVITE_ID=
SENDGRID_TEMPLATE_PASSWORD_RESET_ID=

# Frontend / notificacoes de prazo
APP_FRONTEND_CONTRACT_BASE_URL=http://localhost:3000/contratos
APP_NOTIFICATIONS_EMAIL_PROJECT_DEADLINE_ENABLED=true
APP_NOTIFICATIONS_EMAIL_PROJECT_DEADLINE_CRON=0 0 9 * * *
APP_NOTIFICATIONS_EMAIL_PROJECT_DEADLINE_ZONE=America/Sao_Paulo
APP_NOTIFICATIONS_EMAIL_PROJECT_DEADLINE_DAYS_BEFORE=30,7,1
APP_NOTIFICATIONS_EMAIL_PROJECT_DEADLINE_RECIPIENT_ROLES=SUPERADMIN,ADMIN,OWNER
APP_NOTIFICATIONS_EMAIL_PROJECT_DEADLINE_BATCH_SIZE=200
